# Example environment variables for backend development
# Copy this file to `.env` (or export the variables) and fill with real values.

# Django
DJANGO_SECRET_KEY=replace-me-with-a-secure-key

# Database (Postgres)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Optional: configure allowed hosts, debug override, etc.
DEBUG=True
